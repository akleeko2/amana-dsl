# Linguist — teach GitHub to recognize .amana as a language
*.amana linguist-language=Amana
*.amana linguist-detectable=true

# Normalize line endings
*.rs     text eol=lf
*.amana  text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.json   text eol=lf
*.js     text eol=lf
*.ejs    text eol=lf
*.css    text eol=lf
*.toml   text eol=lf
*.sql    text eol=lf
