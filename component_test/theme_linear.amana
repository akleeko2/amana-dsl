theme:
    preset: linear
    radius: sharp
    density: default
    direction: rtl

route /theme_linear -> view theme_linear

view theme_linear:
    render:
        Container:
            Section:
                h2: "اختبار ثيم Linear"
                Grid(columns: "4"):
                    Card(title: "Flat Card", variant: "flat"):
                        p: "محتوى Flat"
                    Card(title: "Elevated Card", variant: "elevated"):
                        p: "محتوى Elevated"
                    Card(title: "Outlined Card", variant: "outlined"):
                        p: "محتوى Outlined"
                    Card(title: "Glass Card", variant: "glass"):
                        p: "محتوى Glass"
                Cluster:
                    Button(label: "Primary", variant: "primary")
                    Button(label: "Secondary", variant: "secondary")
                    Button(label: "Outline", variant: "outline")
                    Button(label: "Ghost", variant: "ghost")
                    Button(label: "Link", variant: "link")
