app OpsHorizon:
    title: "Ops Horizon"
    db_path: "ops_horizon.db"
    auth_model: User
    capabilities:
        - auth
        - api.rest
        - time

theme:
    mode: day
    direction: ltr
    language: en
    font_provider: google
    font_family: "Inter"
    heading_font_family: "Space Grotesk"
    primary: "#0f766e"
    accent: "#f97316"
    radius: soft
    density: comfortable

tokens:
    colors:
        brand: "#0f766e"
        accent: "#f97316"
        ink: "#111827"
        canvas: "#f7f3ea"
    spacing:
        section: "6rem"
        rail: "1rem"
    radius:
        card: "20px"
        chip: "999px"
    shadows:
        card: "0 12px 30px rgba(17, 24, 39, 0.03)"
        glow: "0 18px 45px rgba(15, 118, 110, 0.15)"

variant Card.command:
    base:
        background: "#ffffff"
        border-radius: "20px"
        box-shadow: "0 10px 30px rgba(17, 24, 39, 0.03)"
        padding: "1.35rem"
        border: "none"
    hover:
        transform: "translateY(-2px)"
        box-shadow: "0 16px 45px rgba(15, 118, 110, 0.08)"

variant Card.tinted:
    base:
        background: "#fdfaf4"
        border: "1px solid rgba(15, 118, 110, 0.08)"
        border-radius: "24px"
        padding: "1.5rem"
        box-shadow: "none"
    hover:
        transform: "translateY(-2px)"

variant Button.cta:
    base:
        background: "linear-gradient(135deg, #0f766e, #14b8a6)"
        color: "#ffffff"
        border-radius: "999px"
        font-weight: "900"
        box-shadow: "0 10px 25px rgba(15, 118, 110, 0.2)"
    hover:
        transform: "translateY(-2px)"
        box-shadow: "0 14px 35px rgba(15, 118, 110, 0.28)"

variant Button.soft:
    base:
        background: "#fff7ed"
        color: "#9a3412"
        border: "1px solid rgba(249, 115, 22, 0.15)"
        border-radius: "999px"
        font-weight: "800"
    hover:
        background: "#ffedd5"

variant Navbar.glass:
    base:
        background: "rgba(255, 255, 255, 0.82)"
        backdrop-filter: "blur(20px)"
        border: "1px solid rgba(17, 24, 39, 0.05)"
        border-radius: "999px"
        box-shadow: "0 12px 30px rgba(17, 24, 39, 0.04)"
        margin-top: "1rem"
        padding: "0.75rem 1.25rem"

model User:
    name: str required min 2 max 90
    email: email unique required
    password: password required min 8
    role: str default "Admin"
    department: str default "Operations"

model Project:
    name: str required max 120
    client: str required max 120
    status: str default "active"
    stage: str default "delivery"
    owner_id: int
    budget: money required min 0
    health_score: int default 82
    due_date: str default "2026-09-30"
    permit Admin manage Project
    permit Manager read Project fields [name, client, status, stage, budget, health_score, due_date]
    permit Manager update Project fields [status, stage, health_score]

model Task:
    title: str required max 140
    project: str required max 120
    assignee: str required max 90
    status: str default "queued"
    priority: str default "medium"
    owner_id: int
    permit Admin manage Task
    permit Manager read Task fields [title, project, assignee, status, priority]
    permit Manager update Task fields [status, priority]

model Incident:
    title: str required max 140
    severity: str default "medium"
    status: str default "investigating"
    owner: str default "SRE"
    response_minutes: int default 18
    permit Admin manage Incident
    permit Manager read Incident fields [title, severity, status, owner, response_minutes]

model Invoice:
    client: str required max 120
    amount: money required min 0
    status: str default "scheduled"
    due_date: str default "2026-08-01"
    permit Admin manage Invoice
    permit Manager read Invoice fields [client, amount, status, due_date]

model TeamMember:
    name: str required max 90
    role: str required max 90
    focus: str required max 140
    capacity: int default 75
    status: str default "available"
    permit Admin manage TeamMember
    permit Manager read TeamMember fields [name, role, focus, capacity, status]

model Lead:
    name: str required max 90
    email: email required
    company: str required max 120
    need: str required max 140
    budget: money default 0
    message: str required max 500
    permit public create Lead fields [name, email, company, need, budget, message]
    permit Admin manage Lead

model Metric:
    label: str required max 80
    value: int required min 0
    category: str default "delivery"
    permit Admin manage Metric
    permit Manager read Metric fields [label, value, category]

