route / -> view Login
route /login -> view Login

route /chat:
    guard User.current != null else redirect /login
    view Chat

route /chat/[id]:
    guard User.current != null else redirect /login
    view Chat

route /prompts:
    guard User.current != null else redirect /login
    view Prompts

route /settings:
    guard User.current != null else redirect /login
    view Settings
