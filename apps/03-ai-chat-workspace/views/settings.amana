view Settings:
    canvas:
        layout: column
        density: comfortable

    render:
        div.app-shell:
            compose:
                layout: dashboard-shell

            aside.side-rail:
                div.logo-area:
                    h3.brand-title: "AI Workspace"

                div.conversations-scroll:
                    a(href: "/chat", class: "conv-item"):
                        span: "← Back to Chat"

                div.sidebar-footer:
                    a(href: "/prompts", class: "nav-footer-link"): "Prompt Library"
                    a(href: "/settings", class: "nav-footer-link"): "Settings"

            main.dashboard-main:
                div.settings-container:
                    div.header-area:
                        h2.settings-title: "Settings"
                        p.settings-subtitle: "Configure your model preferences and user interface"

                    div.settings-card:
                        h3.section-heading: "Model Configuration"
                        div.settings-form-row:
                            div.field-label: "Default Chat Model"
                            div.field-value:
                                select.settings-select(name: "chat_model"):
                                    option(value: "standard"): "Amana GPT-4 (Standard)"
                                    option(value: "fast"): "Amana GPT-3.5 (Fast)"
                                    option(value: "local"): "Amana Custom Local Model"

                        h3.section-heading: "Workspace Interface"
                        div.settings-form-row:
                            div.field-label: "Density Mode"
                            div.field-value:
                                select.settings-select(name: "density_mode"):
                                    option(value: "comfortable"): "Comfortable (Default)"
                                    option(value: "compact"): "Compact"

                        div.settings-form-row:
                            div.field-label: "System Prompt"
                            div.field-value:
                                textarea.settings-textarea(name: "system_prompt", placeholder: "You are a helpful AI..."): "You are Amana AI, a helpful assistant."

                        div.actions-row:
                            Button(label: "Save Changes", click: "alert('Settings saved (mock)')")

    style:
        .app-shell:
            display: flex
            height: 100vh
            overflow: hidden
            background-color: #0f172a
        .side-rail:
            width: 280px
            background-color: #1e293b
            border-right: 1px solid #334155
            display: flex
            flex-direction: column
            padding: md
            gap: md
        .brand-title:
            font-size: lg
            font-weight: 700
            color: #f8fafc
            margin-bottom: sm
        .conversations-scroll:
            flex: 1
            overflow-y: auto
            display: flex
            flex-direction: column
            gap: xs
        .conv-item:
            padding: sm
            border-radius: 4px
            color: #cbd5e1
            text-decoration: none
            font-size: sm
            transition: background 200ms
        .conv-item:hover:
            background: #334155
            color: #f8fafc
        .sidebar-footer:
            border-top: 1px solid #334155
            padding-top: md
            display: flex
            flex-direction: column
            gap: sm
        .nav-footer-link:
            color: #94a3b8
            text-decoration: none
            font-size: sm
        .nav-footer-link:hover:
            color: #f8fafc
        .dashboard-main:
            flex: 1
            display: flex
            flex-direction: column
            height: 100%
            overflow-y: auto
            background-color: #0f172a
        .settings-container:
            padding: xl
            max-width: 600px
            display: flex
            flex-direction: column
            gap: lg
        .settings-title:
            font-size: xl
            font-weight: 700
            color: #f8fafc
        .settings-subtitle:
            font-size: sm
            color: #94a3b8
        .settings-card:
            background-color: #1e293b
            border: 1px solid #334155
            border-radius: 8px
            padding: xl
            display: flex
            flex-direction: column
            gap: md
        .section-heading:
            font-size: md
            font-weight: 600
            color: #cbd5e1
            border-bottom: 1px solid #334155
            padding-bottom: xs
            margin-top: sm
        .settings-form-row:
            display: flex
            flex-direction: column
            gap: xs
            margin-bottom: sm
        .field-label:
            font-size: sm
            font-weight: 500
            color: #94a3b8
        .settings-select:
            width: 100%
            background-color: #0f172a
            color: #f8fafc
            border: 1px solid #334155
            border-radius: 6px
            padding: sm
            font-size: sm
        .settings-textarea:
            width: 100%
            background-color: #0f172a
            color: #f8fafc
            border: 1px solid #334155
            border-radius: 6px
            padding: sm
            font-size: sm
            min-height: 80px
            resize: vertical
        .actions-row:
            margin-top: md
            display: flex
            justify-content: flex-end
