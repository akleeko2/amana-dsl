view Agents:
    protected:
        allow: Agent.current != null
        deny: -> /login
        unauthenticated: -> /login

    canvas:
        layout: dashboard-shell
        density: comfortable
        responsive:
            mobile: stacked

    server:
        fetch agents = Agent.all(limit: 50)

    render:
        div.app-shell:
            SideRail(active_page: "agents")
            main.dashboard-main:
                header.dash-header:
                    div.dash-title-area:
                        h1.dash-title: "Support Team"
                        p.dash-subtitle: "Monitor agent workload, status, and performance"
                    div.dash-actions:
                        Button(label: "Invite Agent", href: "/signup", variant: "primary-glow")

                div.agents-container:
                    div.agents-kpis:
                        MetricCard(label: "Total Agents", value: "12", trend: "↑ 2 this month", color: "brand")
                        MetricCard(label: "Online Now", value: "8", trend: "Active on queue", color: "success")
                        MetricCard(label: "Avg CSAT", value: "95%", trend: "↑ 1pt this week", color: "accent")
                        MetricCard(label: "Resolved Today", value: "132", trend: "↑ 18% vs yesterday", color: "success")

                    div.agents-grid-section:
                        div.section-header-row:
                            h2.section-title: "Agent Overview"
                        ResourceGrid(agents):
                            item AgentCard(agent)
                            empty:
                                EmptyState(title: "No agents yet", description: "Invite your first support agent", action_label: "Invite Agent", action_href: "/signup")
                            loading:
                                p: "Loading team..."
                            error:
                                Alert(tone: "warning", message: "Could not load agents")
                            sort:
                                - tickets_resolved
                                - satisfaction_score

                    div.leaderboard-panel:
                        div.leaderboard-header:
                            h2.leaderboard-title: "Performance Leaderboard"
                            p.leaderboard-sub: "Ranked by tickets resolved this month"
                        div.leaderboard-list:
                            for agent in agents:
                                div.leaderboard-row:
                                    div.lb-rank: "#"
                                    div.lb-avatar: agent.avatar_initials
                                    div.lb-info:
                                        div.lb-name: agent.name
                                        div.lb-dept: agent.department
                                    div.lb-metrics:
                                        div.lb-col:
                                            div.lb-resolved: agent.tickets_resolved
                                            div.lb-metric-label: "Resolved"
                                        div.lb-col:
                                            div.lb-csat: agent.satisfaction_score
                                            div.lb-metric-label: "CSAT %"

    style:
        .app-shell:
            display: "flex"
            background: "#0b0d14"
            width: "100%"
            height: "100%"
            min-height: "0"
            overflow: "hidden"
        .dashboard-main:
            flex: "1"
            min-height: "0"
            overflow-y: "auto"
            display: "flex"
            flex-direction: "column"
            min-width: "0"
        .dash-header:
            display: "flex"
            align-items: "center"
            justify-content: "space-between"
            padding: "1.75rem 2rem 1.25rem"
            border-bottom: "1px solid rgba(255, 255, 255, 0.05)"
            background: "rgba(11, 13, 20, 0.8)"
            backdrop-filter: "blur(20px)"
            position: "sticky"
            top: "0"
            z-index: "10"
            flex-wrap: "wrap"
            gap: "1rem"
            min-width: "0"
            overflow: "hidden"
        .dash-title-area:
            min-width: "0"
        .dash-title:
            font-size: "clamp(1.2rem, 3vw, 1.5rem)"
            font-weight: "800"
            color: "#f1f5f9"
            margin: "0 0 0.2rem"
            letter-spacing: "-0.02em"
            overflow-wrap: "break-word"
            word-break: "break-word"
            max-width: "100%"
        .dash-subtitle:
            font-size: "0.82rem"
            color: "#475569"
            margin: "0"
            overflow-wrap: "break-word"
            max-width: "100%"
        .dash-actions:
            display: "flex"
            gap: "0.75rem"
            flex-shrink: "0"
        .agents-container:
            padding: "1.5rem 2rem"
            flex: "1"
            display: "flex"
            flex-direction: "column"
            gap: "2rem"
        .agents-kpis:
            display: "grid"
            grid-template-columns: "repeat(4, 1fr)"
            gap: "1rem"
            align-items: "start"
        .agents-grid-section:
            display: "flex"
            flex-direction: "column"
            gap: "1rem"
        .section-header-row:
            display: "flex"
            align-items: "center"
            justify-content: "space-between"
        .section-title:
            font-size: "1.05rem"
            font-weight: "700"
            color: "#f1f5f9"
            margin: "0"
        .leaderboard-panel:
            background: "rgba(17, 21, 33, 0.95)"
            border: "1px solid rgba(255, 255, 255, 0.06)"
            border-radius: "18px"
            padding: "1.5rem"
        .leaderboard-header:
            margin-bottom: "1.5rem"
            padding-bottom: "1rem"
            border-bottom: "1px solid rgba(255, 255, 255, 0.05)"
        .leaderboard-title:
            font-size: "1rem"
            font-weight: "700"
            color: "#f1f5f9"
            margin: "0 0 0.2rem"
        .leaderboard-sub:
            font-size: "0.78rem"
            color: "#475569"
            margin: "0"
        .leaderboard-list:
            display: "flex"
            flex-direction: "column"
            gap: "0"
        .leaderboard-row:
            display: "grid"
            grid-template-columns: "32px 40px 1fr auto"
            align-items: "center"
            gap: "1rem"
            padding: "0.9rem 0.5rem"
            border-bottom: "1px solid rgba(255, 255, 255, 0.04)"
            border-radius: "8px"
            transition: "background 200ms ease"
        .leaderboard-row:hover:
            background: "rgba(99, 102, 241, 0.04)"
        .lb-rank:
            font-size: "0.78rem"
            font-weight: "600"
            color: "#475569"
            text-align: "center"
        .lb-avatar:
            width: "36px"
            height: "36px"
            border-radius: "999px"
            background: "linear-gradient(135deg, #6366f1, #22d3ee)"
            display: "flex"
            align-items: "center"
            justify-content: "center"
            font-size: "0.72rem"
            font-weight: "700"
            color: "#ffffff"
        .lb-info:
            min-width: "0"
        .lb-name:
            font-size: "0.88rem"
            font-weight: "600"
            color: "#e2e8f0"
        .lb-dept:
            font-size: "0.72rem"
            color: "#475569"
        .lb-metrics:
            display: "flex"
            gap: "2rem"
            align-items: "center"
        .lb-col:
            text-align: "right"
        .lb-resolved:
            font-size: "1.05rem"
            font-weight: "700"
            color: "#a5b4fc"
        .lb-csat:
            font-size: "0.95rem"
            font-weight: "700"
            color: "#6ee7b7"
        .lb-metric-label:
            font-size: "0.65rem"
            color: "#475569"
            margin-top: "0.1rem"
