model Bot:
    name: str required
    greeting: str
    model_name: str default "gpt-4o"
    temperature: float default 0.7
    owner_id: int foreign_key User(id) on_delete CASCADE

seed Bot:
    row:
        name: "أمانة بوت"
        greeting: "مرحباً بك! أنا مساعدك الذكي، كيف يمكنني خدمتك اليوم؟"
        model_name: "gpt-4o"
        temperature: 0.7
        owner_id: 1
